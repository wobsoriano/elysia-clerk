{
  "name": "elysia-clerk",
  "version": "1.0.0",
  "description": "Unofficial Clerk plugin for Elysia.",
  "keywords": [
    "auth",
    "authentication",
    "bun",
    "clerk",
    "jwt",
    "passwordless",
    "session",
    "typescript"
  ],
  "homepage": "https://github.com/wobsoriano/elysia-clerk#readme",
  "bugs": "https://github.com/wobsoriano/elysia-clerk/issues",
  "license": "MIT",
  "author": "Robert Soriano <sorianorobertc@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wobsoriano/elysia-clerk.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./webhooks": {
      "types": "./dist/webhooks.d.ts",
      "default": "./dist/webhooks.js"
    }
  },
  "scripts": {
    "dev": "bun run --preload ./setup.ts --watch ./dev/index.tsx",
    "build": "vp pack",
    "prepublishOnly": "vp run build",
    "release": "changeset publish",
    "lint": "vp lint",
    "lint:attw": "attw --pack . --profile esm-only",
    "lint:fix": "vp lint --fix",
    "fmt": "vp fmt",
    "fmt:check": "vp fmt --check",
    "test": "vp test",
    "test:watch": "vp test watch"
  },
  "dependencies": {
    "@clerk/backend": "^3.2.2",
    "@clerk/shared": "^4.3.2"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@changesets/cli": "^2.27.10",
    "@elysiajs/eden": "^1.4.8",
    "@elysiajs/html": "^1.4.0",
    "elysia": "^1.4.28",
    "typescript": "6.0.2",
    "vite-plus": "^0.1.11"
  },
  "peerDependencies": {
    "elysia": "^1.4.0"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  }
}
