{
  "name": "elysia-clerk",
  "version": "0.13.2",
  "description": "Unofficial Clerk plugin for Elysia.",
  "keywords": [
    "auth",
    "authentication",
    "bun",
    "clerk",
    "jwt",
    "passwordless",
    "session",
    "typescript"
  ],
  "homepage": "https://github.com/wobsoriano/elysia-clerk#readme",
  "bugs": "https://github.com/wobsoriano/elysia-clerk/issues",
  "license": "MIT",
  "author": "Robert Soriano <sorianorobertc@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wobsoriano/elysia-clerk.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./webhooks": {
      "types": "./dist/webhooks.d.ts",
      "default": "./dist/webhooks.js"
    }
  },
  "scripts": {
    "dev": "bun run --preload ./setup.ts --watch ./dev/index.tsx",
    "build": "tsdown",
    "prepublishOnly": "bun run build",
    "release": "changeset publish",
    "lint": "oxlint",
    "lint:attw": "attw --pack . --profile esm-only",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "bun test --preload ./setup.ts",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@clerk/backend": "^3.2.2",
    "@clerk/shared": "^4.3.2"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@changesets/cli": "^2.27.10",
    "@elysiajs/eden": "^1.4.8",
    "@elysiajs/html": "^1.4.0",
    "@types/bun": "^1.3.11",
    "elysia": "^1.4.28",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "tsdown": "^0.16.4",
    "typescript": "5.5.4"
  },
  "peerDependencies": {
    "elysia": "^1.4.0"
  }
}
